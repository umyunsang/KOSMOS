{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kosmos.dev/schemas/spec-287/tool-call.schema.json",
  "title": "ToolCallFrame",
  "description": "backend → TUI (display only): a tool invocation decision by the model. Direction: backend → TUI.",
  "type": "object",
  "required": ["kind", "session_id", "ts", "call_id", "name", "arguments"],
  "properties": {
    "kind": { "const": "tool_call" },
    "session_id": { "type": "string" },
    "correlation_id": { "type": ["string", "null"] },
    "ts": { "type": "string", "format": "date-time" },
    "call_id": {
      "type": "string",
      "description": "ULID correlating this call to its subsequent tool_result."
    },
    "name": {
      "type": "string",
      "enum": ["lookup", "resolve_location", "submit", "subscribe", "verify"],
      "description": "Primitive name per Spec 031."
    },
    "arguments": {
      "type": "object",
      "description": "Primitive-specific arguments; shape per Spec 031 input schemas."
    }
  },
  "additionalProperties": false
}
