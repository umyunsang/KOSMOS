# KOSAX environment template
# Copy to `.env` (which is a gitignored symlink to your secrets store) and fill in values.
# See docs/configuration.md for the authoritative registry.
# All `<redacted>` placeholders must be replaced with real values before running.
#
# Format note: inline `# ...` on the same line as a value is NOT treated as a
# comment by `src/kosax/_dotenv.py` — the parser strips quotes but does not
# strip trailing `#` comments. Keep all commentary on its own line ABOVE the
# key so that a bare `cp .env.example .env` produces truly empty values and
# triggers `kosax.config.guard` with the single-line remediation message.

# --- User session key (not an operator/Infisical secret) ---
# Public CLI users enter this through /login. Source/self-hosted developers may
# export it locally for backend-only tests. Do not store it in Infisical release
# or operator environments.
# KOSAX_FRIENDLI_TOKEN=

# --- Operator-managed live adapter keys ---
# Public CLI users should not be asked for these keys. Hosted/operator
# deployments keep them server-side; source/self-hosted live-adapter developers
# may set them locally. Never package maintainer key values into wheels, sdists,
# docs, or frontend assets.
# consumed by kosax.settings.KosaxSettings.kakao_api_key
# KOSAX_KAKAO_API_KEY=<redacted>
# consumed by kosax.settings.KosaxSettings.data_go_kr_api_key
# KOSAX_DATA_GO_KR_API_KEY=<redacted>

# --- Optional fallback (resolve_location.py logs-and-skips when unset) ---
# consumed by kosax.settings.KosaxSettings.juso_confm_key
# KOSAX_JUSO_CONFM_KEY=<redacted>
# consumed by kosax.settings.KosaxSettings.sgis_key
# KOSAX_SGIS_KEY=<redacted>
# consumed by kosax.settings.KosaxSettings.sgis_secret
# KOSAX_SGIS_SECRET=<redacted>

# --- Required in prod only (conditional) ---
# consumed by kosax.observability.langfuse (#501)
LANGFUSE_PUBLIC_KEY=<redacted>
# consumed by kosax.observability.langfuse (#501)
LANGFUSE_SECRET_KEY=<redacted>
# consumed by kosax.observability.otel (#501)
KOSAX_OTEL_ENDPOINT=<redacted>

# --- Optional (defaults apply) ---
# activation flag: dev | ci | prod (default dev)
# KOSAX_ENV=dev
# consumed by kosax.llm.config.LLMClientConfig.base_url
# KOSAX_FRIENDLI_BASE_URL=<redacted>
# consumed by kosax.llm.config.LLMClientConfig.model
# KOSAX_FRIENDLI_MODEL=<redacted>
# consumed by kosax.llm.config.LLMClientConfig.session_budget
# KOSAX_LLM_SESSION_BUDGET=<redacted>
# consumed by kosax.settings.KosaxSettings.lookup_topk; clamped [1, 20]
# KOSAX_LOOKUP_TOPK=5
# consumed by kosax.settings.KosaxSettings.nmc_freshness_minutes; clamped [1, 1440]
# KOSAX_NMC_FRESHNESS_MINUTES=30
# consumed by kosax.cli.config.CLIConfig.history_size
# KOSAX_CLI_HISTORY_SIZE=<redacted>
# consumed by kosax.cli.config.CLIConfig.show_usage
# KOSAX_CLI_SHOW_USAGE=<redacted>
# consumed by kosax.cli.config.CLIConfig.welcome_banner
# KOSAX_CLI_WELCOME_BANNER=<redacted>
# consumed by kosax.cli.themes.load_theme (alias for KOSAX_THEME)
# KOSAX_CLI_THEME=<redacted>
# consumed by kosax.cli.themes.load_theme
# KOSAX_THEME=<redacted>

# --- Override pattern (escape hatch) ---
# per-tool override, e.g. KOSAX_KOROAD_ACCIDENT_SEARCH_API_KEY; see docs/configuration.md
# KOSAX_<TOOL_ID>_API_KEY=<redacted>

# --- Deprecated (scheduled for removal) ---
# legacy global fallback — do not set in new installs; consumed by kosax.permissions.credentials (global fallback)
# KOSAX_API_KEY=<redacted>

# OTLP Collector (spec 028)
# consumed by docker-compose.dev.yml — host port of the otelcol OTLP HTTP receiver
KOSAX_OTEL_COLLECTOR_PORT=4318
# consumed by infra/otel-collector/config.yaml — base OTLP URL (collector appends /v1/traces automatically)
KOSAX_LANGFUSE_OTLP_ENDPOINT=http://langfuse-web:3000/api/public/otel
# consumed by infra/otel-collector/config.yaml — Basic <base64(pk-xxx:sk-xxx)> for Langfuse OTLP auth (empty = anonymous)
KOSAX_LANGFUSE_OTLP_AUTH_HEADER=
