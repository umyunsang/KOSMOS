#!/usr/bin/env expect
# PTY smoke driver — PR #2519 hotfix verification (Korean IME Enter swallow fix)
#
# Scope: ASCII-only Layer 2 verification that the BaseTextInput.tsx:60 edit
# (removing the `if (isPasting && key.return) return` guard) does NOT break
# the normal slash-command + Enter path. Korean IME composition cannot be
# simulated through expect — that requires a human at a real terminal with
# a Hangul IME. See specs/2519-korean-ime-enter-fix/MANUAL-TEST.md for the
# user-driven Korean IME validation steps.
#
# Verification:
#   expect -n smoke-2519-boot.expect   (syntax check)
#   expect smoke-2519-boot.expect      (full run — TUI must be runnable)
#
# Captures PTY output to ../smoke-2519-boot-pty.txt for grep / LLM review.

set timeout 60

set log_path [file normalize "[file dirname [info script]]/../smoke-2519-boot-pty.txt"]
log_file -noappend $log_path

# Spawn TUI.
spawn bash -c "cd [file normalize [file join $env(HOME) KOSMOS tui]] && bun run tui"

# Await KOSMOS branding.
expect {
    "KOSMOS" {
        # Branding confirmed.
    }
    timeout {
        puts stderr "\[SMOKE ERROR\] Timed out waiting for KOSMOS branding"
        exit 1
    }
    eof {
        puts stderr "\[SMOKE ERROR\] TUI process exited before branding rendered"
        exit 1
    }
}

# Wait for prompt to settle.
sleep 3

# Send /help via real Enter (\r) — the keystroke that the BaseTextInput edit
# now lets through unconditionally. If the swallow regression returned, the
# slash command would never dispatch and the help banner would not appear.
send "/help\r"

expect {
    -re {Help|/clear|/exit|/login} {
        # Help banner rendered — Enter dispatched the command successfully.
    }
    timeout {
        puts stderr "\[SMOKE ERROR\] Help banner did not render after /help + Enter"
        exit 1
    }
    eof {
        puts stderr "\[SMOKE ERROR\] TUI exited before help banner rendered"
        exit 1
    }
}

sleep 2

# Send a second Enter on an empty input — should not crash, should not freeze.
send "\r"
sleep 1

# Ctrl+C twice to terminate cleanly.
send "\003"
sleep 1
send "\003"

expect {
    eof {
        # Clean exit.
    }
    timeout {
        puts stderr "\[SMOKE WARN\] TUI did not exit cleanly after Ctrl+C"
    }
}

puts "SMOKE PASS: /help dispatched via Enter, PTY log captured to $log_path"
