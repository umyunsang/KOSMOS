# KOSMOS Environment Variables
# Copy to .env and fill in your keys. NEVER commit .env to git.

# ──────────────────────────────────────────────────────────────
# data.go.kr Public Data Portal — unified authentication key
# Register: https://www.data.go.kr (sign up → apply for each API)
# One key covers ALL data.go.kr APIs below:
#   KOROAD traffic accidents, road risk index
#   KMA weather alerts, short-term forecast
#   NMC emergency medical facilities
#   HIRA hospital info, hospital detail info
#   SSIS central/local welfare services
#   Gov24 public service benefits
#   MOLIT vehicle info
#   MOIS disaster action guidelines
# Quota: 1,000–10,000 calls/day per API (dev account)
# ──────────────────────────────────────────────────────────────
KOSMOS_DATA_GO_KR_KEY=

# ──────────────────────────────────────────────────────────────
# KOROAD Open Data Portal — traffic accident & safety APIs (16 types)
# Register: https://opendata.koroad.or.kr/api/apiKeyUserView.do
# Covers: 12 accident hotspot APIs + 3 traffic safety + 1 statistics
# Endpoint base: apis.data.go.kr/B552061/
# Codelist: research/data/koroad/AccidentHazard_CodeList.xlsx
# ──────────────────────────────────────────────────────────────
KOSMOS_KOROAD_API_KEY=

# ──────────────────────────────────────────────────────────────
# Disaster Safety Data Sharing Platform (safetydata.go.kr)
# Register: https://www.safetydata.go.kr/registMember_1
# Used for: emergency disaster text alerts (dataSn=228)
# NOTE: Separate account required — data.go.kr key does NOT work
# ──────────────────────────────────────────────────────────────
KOSMOS_SAFETYDATA_KEY=

# ──────────────────────────────────────────────────────────────
# FriendliAI Serverless API token (K-EXAONE LLM inference)
# Register: https://friendli.ai/suite → Personal settings → Tokens
# Model: LGAI-EXAONE/K-EXAONE-236B-A23B
# Base URL: https://api.friendli.ai/serverless/v1
# Pricing: input $0.2/1M tokens, output $0.8/1M tokens
# ──────────────────────────────────────────────────────────────
KOSMOS_FRIENDLI_TOKEN=

# ──────────────────────────────────────────────────────────────
# [Optional] KMA API Hub — advanced weather data (Phase 2+)
# Register: https://apihub.kma.go.kr
# General member: 20,000 calls/day, 5GB
# ──────────────────────────────────────────────────────────────
# KOSMOS_KMA_API_HUB_KEY=
