#!/usr/bin/env expect -f
# Layer 2 PTY smoke — FR-017 / SC-002
# Contract: specs/2298-system-prompt-rewrite/contracts/smoke-checkpoint-protocol.md § 1
#
# Scenario: citizen sends a comprehensive income tax return request.
# The LLM must invoke verify_chain (modid → hometax_simplified → hometax_taxreturn)
# and emit a receipt id matching: hometax-2026-\d{2}-\d{2}-RX-[A-Z0-9]{5}
# On first match → emit CHECKPOINTreceipt token observed (exactly once).

set timeout 60

# Tee everything to the log file (§ 1.2 step 8)
log_file -a "specs/2298-system-prompt-rewrite/smoke-citizen-taxreturn-pty.txt"

# --- Step 1: spawn TUI from worktree root ---
spawn bash -c "cd /Users/um-yunsang/KOSMOS-w-2298 && bun run tui"

# --- Step 2: assert KOSMOS boot banner ---
expect {
    -re {KOSMOS} {
        puts "CHECKPOINTboot KOSMOS banner observed"
    }
    timeout {
        puts "ERROR: KOSMOS banner not observed within timeout"
        exit 1
    }
}

# --- Step 3: 2 s settling delay (session_id + permission scaffold) ---
sleep 2

# --- Step 4: send the citizen prompt ---
send -- "내 종합소득세 신고해줘\r"

# --- Step 5: poll assistant_chunk stream for receipt regex ---
# De-duplication flag (SC-002): emit CHECKPOINTreceipt exactly once
set checkpoint_emitted 0

# Poll loop: match receipt id OR timeout each cycle
set poll_limit 20
set poll_count 0

while {$poll_count < $poll_limit} {
    expect {
        -re {hometax-2026-[0-9][0-9]-[0-9][0-9]-RX-[A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9][A-Z0-9]} {
            if {!$checkpoint_emitted} {
                puts "CHECKPOINTreceipt token observed"
                set checkpoint_emitted 1
            }
            # Receipt matched — break out of loop
            set poll_count $poll_limit
        }
        timeout {
            incr poll_count
        }
    }
}

# --- Step 6: continue capturing for 5 s after checkpoint (full Korean response) ---
expect {
    timeout {}
}

# --- Step 7: double Ctrl-C exit ---
send -- "\003\003"
expect eof
