{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kosmos.dev/schemas/spec-287/coordinator-phase.schema.json",
  "title": "CoordinatorPhaseFrame",
  "description": "backend → TUI: Spec 027 coordinator phase update. Direction: backend → TUI. Rendering MUST NOT disrupt an active streaming message (FR-043).",
  "type": "object",
  "required": ["kind", "session_id", "ts", "phase"],
  "properties": {
    "kind": { "const": "coordinator_phase" },
    "session_id": { "type": "string" },
    "correlation_id": { "type": ["string", "null"] },
    "ts": { "type": "string", "format": "date-time" },
    "phase": {
      "type": "string",
      "enum": ["Research", "Synthesis", "Implementation", "Verification"]
    }
  },
  "additionalProperties": false
}
