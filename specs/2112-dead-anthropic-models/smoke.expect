#!/usr/bin/env expect
# KOSMOS Epic #2112 — citizen smoke (text-log capture per memory feedback_vhs_tui_smoke).
# Output: specs/2112-dead-anthropic-models/smoke.txt (LLM/Codex grep-able plain text).

set timeout 120

# Resolve repo paths from the script location (script is in specs/2112-.../).
set script_dir [file normalize [file dirname [info script]]]
set repo_root [file normalize [file join $script_dir ".." ".."]]
set tui_dir [file join $repo_root "tui"]

log_file -a [file join $script_dir "smoke.txt"]

# bun run tui resolves "tui" against the cwd's package.json — must be tui/.
cd $tui_dir

spawn bun run tui
expect ">"

send "Hi\r"
sleep 15

send "강남역 어디?\r"
sleep 50

send "/quit\r"
sleep 3

expect eof
