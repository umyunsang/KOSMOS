{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdapterRegistration",
  "description": "Per-adapter registry metadata. Spec 031 adds primitive + dual-axis (published_tier_minimum, nist_aal_hint) on top of Spec 024 (auth_type/auth_level/pipa_class/is_irreversible) and Spec 025 V6 (auth_type↔auth_level allow-list) invariants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool_id",
    "primitive",
    "module_path",
    "input_model_ref",
    "source_mode",
    "requires_auth",
    "is_personal_data",
    "is_concurrency_safe",
    "cache_ttl_seconds",
    "rate_limit_per_minute",
    "search_hint",
    "auth_type",
    "auth_level",
    "pipa_class",
    "is_irreversible"
  ],
  "properties": {
    "tool_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Globally unique. Collision rejected at registration (FR-020)."
    },
    "primitive": {
      "type": "string",
      "enum": ["lookup", "resolve_location", "submit", "subscribe", "verify"]
    },
    "module_path": {
      "type": "string",
      "description": "Dotted Python module path, e.g. kosmos.tools.mock.data_go_kr.fines_pay."
    },
    "input_model_ref": {
      "type": "string",
      "description": "Dotted reference to the adapter's Pydantic input model class."
    },
    "source_mode": {
      "type": "string",
      "enum": ["OPENAPI", "OOS", "harness-only"],
      "description": "OPENAPI = byte-mirrored from public OpenAPI spec. OOS = shape-mirrored from open-source SDK / reference impl. harness-only = net-new with no external byte/shape mirror."
    },
    "published_tier_minimum": {
      "type": ["string", "null"],
      "enum": [
        "gongdong_injeungseo_personal_aal3",
        "gongdong_injeungseo_corporate_aal3",
        "gongdong_injeungseo_bank_only_aal2",
        "geumyung_injeungseo_personal_aal2",
        "geumyung_injeungseo_business_aal3",
        "ganpyeon_injeung_pass_aal2",
        "ganpyeon_injeung_kakao_aal2",
        "ganpyeon_injeung_naver_aal2",
        "ganpyeon_injeung_toss_aal2",
        "ganpyeon_injeung_bank_aal2",
        "ganpyeon_injeung_samsung_aal2",
        "ganpyeon_injeung_payco_aal2",
        "digital_onepass_level1_aal1",
        "digital_onepass_level2_aal2",
        "digital_onepass_level3_aal3",
        "mobile_id_mdl_aal2",
        "mobile_id_resident_aal2",
        "mydata_individual_aal2",
        null
      ],
      "description": "Required on/after v1.2 GA (FR-030). Pre-v1.2 registrations may be null during the compatibility window (FR-028)."
    },
    "nist_aal_hint": {
      "type": ["string", "null"],
      "enum": ["AAL1", "AAL2", "AAL3", null],
      "description": "Advisory secondary axis. Required on/after v1.2 GA (FR-030)."
    },
    "requires_auth": {
      "type": "boolean",
      "default": true,
      "description": "Fail-closed default (Constitution §II). FR-038 invariant: is_personal_data=true → requires_auth=true ∧ auth_level ≠ public."
    },
    "is_personal_data": {"type": "boolean", "default": true},
    "is_concurrency_safe": {"type": "boolean", "default": false},
    "cache_ttl_seconds": {"type": "integer", "minimum": 0, "default": 0},
    "rate_limit_per_minute": {"type": "integer", "minimum": 1, "default": 10},
    "search_hint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ko": {"type": "array", "items": {"type": "string"}},
        "en": {"type": "array", "items": {"type": "string"}}
      },
      "description": "Bilingual Korean + English discovery keywords (Constitution §III)."
    },
    "auth_type": {
      "type": "string",
      "enum": ["public", "api_key", "oauth"],
      "description": "Spec 024 field. V6 allow-list with auth_level (Spec 025)."
    },
    "auth_level": {
      "type": "string",
      "enum": ["public", "AAL1", "AAL2", "AAL3"],
      "description": "Spec 024 field. V3 canonical mapping enforced via @model_validator + ToolRegistry.register() backstop."
    },
    "pipa_class": {
      "type": "string",
      "enum": ["non_personal", "personal_standard", "personal_sensitive", "personal_unique_id"],
      "description": "Spec 024 PIPA classification."
    },
    "is_irreversible": {
      "type": "boolean",
      "default": false,
      "description": "V1 invariant: primitive=submit ∧ pipa_class ∈ {personal_*} → is_irreversible=true unless explicit audit-preservation contract."
    },
    "dpa_reference": {
      "type": ["string", "null"],
      "description": "Data Processing Agreement reference (Spec 024 extension)."
    }
  },
  "allOf": [
    {
      "description": "V6 allow-list: (auth_type, auth_level) ∈ {public⇒{public,AAL1}, api_key⇒{AAL1,AAL2,AAL3}, oauth⇒{AAL1,AAL2,AAL3}}.",
      "oneOf": [
        {
          "properties": {
            "auth_type": {"const": "public"},
            "auth_level": {"enum": ["public", "AAL1"]}
          }
        },
        {
          "properties": {
            "auth_type": {"const": "api_key"},
            "auth_level": {"enum": ["AAL1", "AAL2", "AAL3"]}
          }
        },
        {
          "properties": {
            "auth_type": {"const": "oauth"},
            "auth_level": {"enum": ["AAL1", "AAL2", "AAL3"]}
          }
        }
      ]
    }
  ]
}
