#!/usr/bin/env bun
// SPDX-License-Identifier: Apache-2.0

import { dirname, join } from 'node:path'
import { fileURLToPath } from 'node:url'

function bunVersionAtLeast(version: string, minimum: string): boolean {
  const current = version.split('.').map((part) => Number(part))
  const required = minimum.split('.').map((part) => Number(part))
  for (let index = 0; index < required.length; index += 1) {
    const left = current[index] ?? 0
    const right = required[index] ?? 0
    if (left > right) return true
    if (left < right) return false
  }
  return true
}

if (!bunVersionAtLeast(Bun.version, '1.3.0')) {
  process.stderr.write(
    `KOSAX requires Bun >= 1.3.0; found ${Bun.version}. Install or upgrade Bun before running kosax.\n`,
  )
  process.exit(1)
}

const packageRoot = dirname(dirname(fileURLToPath(import.meta.url)))

process.env.KOSAX_PACKAGE_ROOT ??= packageRoot
process.env.KOSAX_BACKEND_CMD_JSON ??= JSON.stringify([
  'uv',
  '--directory',
  packageRoot,
  'run',
  'kosax',
  '--ipc',
  'stdio',
])

await import(join(packageRoot, 'tui/src/stubs/macro-preload.ts'))
await import(join(packageRoot, 'tui/src/entrypoints/cli.tsx'))
