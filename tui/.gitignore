# Spec 287: KOSMOS TUI — Ink + React + Bun
# tui/.gitignore
#
# NOTE: bun.lockb is intentionally NOT ignored.
# Bun best practice is to commit the lockfile so all contributors and CI
# reproduce the exact same dependency resolution.
# (Ref: https://bun.sh/docs/install/lockfile)
#
# NOTE: src/ipc/frames.generated.ts is also intentionally NOT ignored.
# It is the single code-gen artifact that must be committed so the repo
# is self-contained and CI does not require a live Python process to
# type-check. All other *.generated.ts files produced at runtime should
# NOT be committed.

# --- Dependencies ---
node_modules/

# --- Code-generation runtime artifacts ---
# Ignore all *.generated.ts except the committed artifacts.
*.generated.ts
!src/ipc/frames.generated.ts
# Spec 1636 P5: PIPA canonical hash mirror — generated by
# tui/scripts/gen-pipa-hash.ts from the Python source-of-truth so
# /plugin pipa-text always shows the live hash without import-time
# Python bridge calls.
!src/ipc/pipa.generated.ts
# Epic #1632 P0 baseline runnable — hand-written stubs that match the CC
# 2.1.88 sourcemap's generated file naming. Real implementations are
# tracked for recovery in Epic #1633 (dead code elimination may remove
# callers entirely). Committing keeps `bun run test`/`bun run typecheck`
# self-contained without requiring a code-generation step in CI.
!src/entrypoints/sdk/coreTypes.generated.ts
!src/entrypoints/sdk/settingsTypes.generated.ts

# --- Build outputs ---
dist/
build/
out/

# --- Bun single-binary compile outputs (T126) ---
*.binary
*.exe

# --- Environment secrets ---
.env*
!.env.example

# --- Test coverage ---
coverage/

# --- OS artifacts ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
