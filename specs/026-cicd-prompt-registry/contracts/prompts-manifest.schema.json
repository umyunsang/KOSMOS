{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kosmos.umyunsang.dev/schemas/026-cicd-prompt-registry/prompts-manifest.schema.json",
  "title": "KOSMOS Prompt Registry Manifest",
  "description": "Schema for prompts/manifest.yaml. Mirrors the Pydantic v2 PromptManifest model in data-model.md. Validated in CI before platform startup.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "entries"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Manifest schema version. Currently 1."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of prompt entries. At first release MUST contain system_v1, session_guidance_v1, and compact_v1.",
      "items": {
        "$ref": "#/$defs/promptManifestEntry"
      },
      "uniqueItems": false
    }
  },
  "$defs": {
    "promptManifestEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_id", "version", "sha256", "path"],
      "properties": {
        "prompt_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$",
          "minLength": 3,
          "maxLength": 64,
          "description": "snake_case identifier ending in _v{N}. The numeric suffix MUST equal the version field."
        },
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Monotonic version integer. MUST equal the _v{N} suffix of prompt_id."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "minLength": 64,
          "maxLength": 64,
          "description": "Lowercase hex SHA-256 digest of the file bytes at path."
        },
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_\\-./]+$",
          "minLength": 1,
          "maxLength": 256,
          "description": "Path relative to the prompts/ directory. Must not contain '..' segments."
        }
      }
    }
  },
  "examples": [
    {
      "version": 1,
      "entries": [
        {
          "prompt_id": "system_v1",
          "version": 1,
          "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "path": "system_v1.md"
        },
        {
          "prompt_id": "session_guidance_v1",
          "version": 1,
          "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "path": "session_guidance_v1.md"
        },
        {
          "prompt_id": "compact_v1",
          "version": 1,
          "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
          "path": "compact_v1.md"
        }
      ]
    }
  ]
}
