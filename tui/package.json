{
  "name": "@kosmos/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2.0 <1.3.0"
  },
  "scripts": {
    "tui": "bun run src/cli.tsx",
    "gen:ipc": "bun run scripts/gen-ipc-types.ts",
    "diff:upstream": "bun run scripts/diff-upstream.ts",
    "tui:fixture": "bun run scripts/fixture-runner.ts",
    "test:soak": "bun test --timeout 600000 tests/soak",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "npm:@jrichman/ink@6.6.9",
    "react": "^19.2.0",
    "@inkjs/ui": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "bun-types": "latest",
    "ink-testing-library": "^4.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.6.0"
  }
}
