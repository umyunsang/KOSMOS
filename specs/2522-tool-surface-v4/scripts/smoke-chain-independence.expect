#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Spec 2522 T048 — TUI PTY smoke scenario 7: chain 독립 + LLM autonomous chain (US7)
#
# Pattern: scripts/tui-tmux-capture.sh (tmux capture-pane, NOT asciinema-in-asciinema)
# Memory: feedback_debug_infra_rebuild — wait_for_pane <regex> <deadline>, no hardcoded sleep
#
# Verification targets:
#
#   Scenario A: "lat 37.5 lon 127.0 병원"
#     1. Boot: "tool_registry: N entries verified"
#     2. Branding: "KOSMOS"
#     3. Input accepted
#     4. LLM calls hira_hospital_search DIRECTLY (single turn, ≤120s)
#        Gate pattern: "● lookup(hira" — TUI dispatch bullet from actual tool call
#     5. No resolve_location call before hira — KOSMOS does NOT force cross-domain chain
#     6. shortcuts footer reappears (turn complete)
#
#   Scenario B: "강남구 병원"
#     1. Same boot/branding checks (reused from A, TUI still running)
#     2. LLM autonomously calls resolve_location (turn 1)
#        Gate pattern: "● resolve_location" — TUI dispatch bullet
#     3. LLM autonomously calls hira_hospital_search (turn 2)
#        Gate pattern: "● lookup(hira" — TUI dispatch bullet
#     4. KOSMOS did NOT hardcode this chain — LLM decided from tool descriptions
#     5. shortcuts footer reappears (turn complete)
#
# Pattern design notes:
#   - "● lookup(hira" matches the TUI dispatch line, NOT the user query text
#   - "● resolve_location" matches the TUI dispatch line, NOT user query text
#   - K-EXAONE high-effort reasoning: 30-90s per turn → use 120s deadlines
#   - shortcuts footer: "? for shortcuts" reappears only when REPL is ready
#
# Sourced by tui-tmux-capture.sh — helpers available:
#   wait_for_pane, snapshot_pane, send_text_pane, send_enter_pane, send_ctrlc_pane

# ---------------------------------------------------------------------------
# SCENARIO A: lat/lon 직접 제공 — single-turn, no resolve_location
# ---------------------------------------------------------------------------

# Stage A1: Wait for backend boot
wait_for_pane "tool_registry: [0-9]+ entries verified" 45
snapshot_pane "A-boot"

# Stage A2: Wait for KOSMOS branding / REPL ready
wait_for_pane "shortcuts" 20
snapshot_pane "A-branding"

# Stage A3: Submit scenario A query — lat/lon given directly in message
send_text_pane "lat 37.5 lon 127.0 병원"
snapshot_pane "A-input-typed"
send_enter_pane
snapshot_pane "A-input-submitted"

# Stage A4: Wait for HIRA dispatch bullet from TUI (≤120s)
# K-EXAONE high-effort reasoning: 30-90s. Pattern matches TUI bullet "● lookup(hira".
# Does NOT match user query text (which contains neither "●" nor "lookup").
wait_for_pane "(● lookup.hira|hira_hospital_search|● resolve_location)" 120
snapshot_pane "A-tool-dispatched"

# Stage A5: Wait for tool result (⎿) or response completion
# After hira returns, LLM streams final text. Gate: shortcuts footer or ⎿ result.
wait_for_pane "(shortcuts|⎿)" 60
snapshot_pane "A-response-partial"

# Stage A6: Final capture — if still thinking, wait for shortcuts footer (turn done)
wait_for_pane "shortcuts" 60
snapshot_pane "A-response-complete"

# Stage A7: Final capture — documents that resolve_location was NOT the first call
snapshot_pane "A-final"

# ---------------------------------------------------------------------------
# SCENARIO B: address-only — autonomous 2-turn chain (resolve_location → HIRA)
# ---------------------------------------------------------------------------

# Stage B1: Submit scenario B query — address only, no coordinates
send_text_pane "강남구 병원"
snapshot_pane "B-input-typed"
send_enter_pane
snapshot_pane "B-input-submitted"

# Stage B2: Wait for resolve_location dispatch bullet (turn 1)
# LLM must call resolve_location before HIRA when only an address is given.
# Gate pattern: "● resolve_location" — TUI tool dispatch bullet.
# K-EXAONE reasoning: 30-90s → 120s deadline.
wait_for_pane "● resolve_location" 120
snapshot_pane "B-resolve-dispatched"

# Stage B3: Wait for HIRA dispatch bullet (turn 2 — autonomous chain)
# After resolve_location returns coords, LLM calls hira_hospital_search.
# Extra time budget: resolve_location network call + turn-2 reasoning.
wait_for_pane "(● lookup.hira|hira_hospital_search)" 120
snapshot_pane "B-hira-dispatched"

# Stage B4: Wait for final text response (turn complete)
# Gate: shortcuts footer reappears.
wait_for_pane "shortcuts" 60
snapshot_pane "B-response-complete"

# Stage B5: Final capture
snapshot_pane "B-final"

# Quit cleanly
send_text_pane "/quit"
send_enter_pane
