{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerifyOutput",
  "description": "Discriminated union over 6 authentication families plus a structured mismatch branch. Primary axis = published_tier (18 ratified Korean labels); nist_aal_hint is advisory only (FR-007, FR-008).",
  "oneOf": [
    {"$ref": "#/$defs/GongdongInjeungseoContext"},
    {"$ref": "#/$defs/GeumyungInjeungseoContext"},
    {"$ref": "#/$defs/GanpyeonInjeungContext"},
    {"$ref": "#/$defs/DigitalOnepassContext"},
    {"$ref": "#/$defs/MobileIdContext"},
    {"$ref": "#/$defs/MyDataContext"},
    {"$ref": "#/$defs/VerifyMismatchError"}
  ],
  "$defs": {
    "PublishedTier": {
      "type": "string",
      "description": "18 ratified Korean published_tier labels (Spec 031 research §2). Enum is closed in v1; extensions require spec amendment.",
      "enum": [
        "gongdong_injeungseo_personal_aal3",
        "gongdong_injeungseo_corporate_aal3",
        "gongdong_injeungseo_bank_only_aal2",
        "geumyung_injeungseo_personal_aal2",
        "geumyung_injeungseo_business_aal3",
        "ganpyeon_injeung_pass_aal2",
        "ganpyeon_injeung_kakao_aal2",
        "ganpyeon_injeung_naver_aal2",
        "ganpyeon_injeung_toss_aal2",
        "ganpyeon_injeung_bank_aal2",
        "ganpyeon_injeung_samsung_aal2",
        "ganpyeon_injeung_payco_aal2",
        "digital_onepass_level1_aal1",
        "digital_onepass_level2_aal2",
        "digital_onepass_level3_aal3",
        "mobile_id_mdl_aal2",
        "mobile_id_resident_aal2",
        "mydata_individual_aal2"
      ]
    },
    "NistAalHint": {
      "type": "string",
      "enum": ["AAL1", "AAL2", "AAL3"],
      "description": "Advisory NIST SP 800-63-4 AAL hint. Consumers MUST be able to branch on published_tier without reading this (FR-008)."
    },
    "_BaseFields": {
      "type": "object",
      "properties": {
        "published_tier": {"$ref": "#/$defs/PublishedTier"},
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time", "description": "RFC 3339 with timezone."},
        "external_session_ref": {"type": ["string", "null"], "description": "Opaque reference to the external provider session. KOSMOS holds no signing keys."}
      }
    },
    "GongdongInjeungseoContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "certificate_issuer"],
      "properties": {
        "family": {"const": "gongdong_injeungseo"},
        "published_tier": {
          "type": "string",
          "enum": [
            "gongdong_injeungseo_personal_aal3",
            "gongdong_injeungseo_corporate_aal3",
            "gongdong_injeungseo_bank_only_aal2"
          ]
        },
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "certificate_issuer": {"type": "string", "minLength": 1, "description": "Issuing CA name (e.g. KICA, KFTC, TradeSign)."}
      }
    },
    "GeumyungInjeungseoContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "bank_cluster"],
      "properties": {
        "family": {"const": "geumyung_injeungseo"},
        "published_tier": {
          "type": "string",
          "enum": ["geumyung_injeungseo_personal_aal2", "geumyung_injeungseo_business_aal3"]
        },
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "bank_cluster": {"type": "string", "enum": ["kftc"], "description": "금융결제원 클라우드 cluster identifier."}
      }
    },
    "GanpyeonInjeungContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "provider"],
      "properties": {
        "family": {"const": "ganpyeon_injeung"},
        "published_tier": {
          "type": "string",
          "enum": [
            "ganpyeon_injeung_pass_aal2",
            "ganpyeon_injeung_kakao_aal2",
            "ganpyeon_injeung_naver_aal2",
            "ganpyeon_injeung_toss_aal2",
            "ganpyeon_injeung_bank_aal2",
            "ganpyeon_injeung_samsung_aal2",
            "ganpyeon_injeung_payco_aal2"
          ]
        },
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "provider": {
          "type": "string",
          "enum": ["pass", "kakao", "naver", "toss", "bank", "samsung", "payco"]
        }
      }
    },
    "DigitalOnepassContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "level"],
      "properties": {
        "family": {"const": "digital_onepass"},
        "published_tier": {
          "type": "string",
          "enum": [
            "digital_onepass_level1_aal1",
            "digital_onepass_level2_aal2",
            "digital_onepass_level3_aal3"
          ]
        },
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "level": {"type": "integer", "enum": [1, 2, 3]}
      }
    },
    "MobileIdContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "id_type"],
      "properties": {
        "family": {"const": "mobile_id"},
        "published_tier": {
          "type": "string",
          "enum": ["mobile_id_mdl_aal2", "mobile_id_resident_aal2"]
        },
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "id_type": {"type": "string", "enum": ["mdl", "resident"], "description": "모바일운전면허 | 모바일주민등록증"}
      }
    },
    "MyDataContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "published_tier", "nist_aal_hint", "verified_at", "provider_id"],
      "properties": {
        "family": {"const": "mydata"},
        "published_tier": {"type": "string", "enum": ["mydata_individual_aal2"]},
        "nist_aal_hint": {"$ref": "#/$defs/NistAalHint"},
        "verified_at": {"type": "string", "format": "date-time"},
        "external_session_ref": {"type": ["string", "null"]},
        "provider_id": {"type": "string", "minLength": 1, "description": "마이데이터 사업자 코드."}
      }
    },
    "VerifyMismatchError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "reason", "expected_family", "observed_family", "message"],
      "properties": {
        "family": {"const": "mismatch_error", "description": "Discriminator value for structured mismatch (FR-010)."},
        "reason": {"const": "family_mismatch"},
        "expected_family": {"type": "string"},
        "observed_family": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  }
}
