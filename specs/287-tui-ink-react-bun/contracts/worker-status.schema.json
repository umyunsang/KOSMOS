{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ummaya.dev/schemas/spec-287/worker-status.schema.json",
  "title": "WorkerStatusFrame",
  "description": "backend → TUI: per-worker status row update from Spec 027 swarm + Spec #14 role labels. Direction: backend → TUI.",
  "type": "object",
  "required": ["kind", "session_id", "ts", "worker_id", "role_id", "current_primitive", "status"],
  "properties": {
    "kind": { "const": "worker_status" },
    "session_id": { "type": "string" },
    "correlation_id": { "type": ["string", "null"] },
    "ts": { "type": "string", "format": "date-time" },
    "worker_id": { "type": "string" },
    "role_id": {
      "type": "string",
      "description": "Specialist label from #14 (e.g., transport-specialist, health-specialist, emergency-specialist)."
    },
    "current_primitive": {
      "type": "string",
      "enum": ["find", "locate", "send", "subscribe", "check"]
    },
    "status": {
      "type": "string",
      "enum": ["idle", "running", "waiting_permission", "error"]
    }
  },
  "additionalProperties": false
}
