#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Spec 2522 T048 — TUI PTY smoke scenario 7B only: autonomous chain (강남구 병원)
# Run separately from smoke-chain-independence.expect to isolate scenario B timing.

# Stage B1: Wait for backend boot
wait_for_pane "tool_registry: [0-9]+ entries verified" 45
snapshot_pane "B-boot"

# Stage B2: Wait for REPL ready
wait_for_pane "shortcuts" 20
snapshot_pane "B-branding"

# Stage B3: Submit scenario B query — address only
send_text_pane "강남구 병원"
snapshot_pane "B-input-typed"
send_enter_pane
snapshot_pane "B-input-submitted"

# Stage B4: Wait for first tool dispatch (resolve_location OR hira_hospital_search)
# LLM may chain resolve_location → hira OR directly call hira if it knows coords.
# Both are valid autonomous behaviors — KOSMOS does NOT mandate the chain.
# K-EXAONE high-effort reasoning: 30-90s → 120s deadline.
wait_for_pane "(● resolve_location|● lookup.hira|hira_hospital_search)" 120
snapshot_pane "B-first-tool"

# Stage B5: Wait for possible second tool (if resolve_location was first)
# If first tool was resolve_location, wait for hira_hospital_search dispatch.
# If first tool was hira directly, this wait will pass immediately on shortcuts.
wait_for_pane "(● lookup.hira|hira_hospital_search|shortcuts)" 120
snapshot_pane "B-second-tool-or-complete"

# Stage B6: Wait for final response (shortcuts footer reappears)
wait_for_pane "shortcuts" 60
snapshot_pane "B-response-complete"

# Stage B7: Final capture
snapshot_pane "B-final"

# Quit cleanly
send_text_pane "/quit"
send_enter_pane
