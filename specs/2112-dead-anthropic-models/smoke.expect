#!/usr/bin/env expect
# KOSMOS Epic #2112 — Citizen E2E smoke (text-log capture, multi-scenario).
# Companion to smoke.tape (visual capture). This file is the LLM/Codex grep
# source-of-truth per memory feedback_vhs_tui_smoke.
#
# Output: specs/2112-dead-anthropic-models/smoke.txt
#
# Scenarios (mirrors smoke.tape):
#   1. Korean greeting          — "안녕하세요"
#   2. Help command             — "/help"
#   3. Public-service lookup    — "강남역 어디야?"
#   4. Weather routing          — "오늘 서울 날씨 알려줘"
#   5. Clean exit               — "/quit"

set timeout 240

# Resolve repo paths from the script location.
set script_dir [file normalize [file dirname [info script]]]
set repo_root  [file normalize [file join $script_dir ".." ".."]]
set tui_dir    [file join $repo_root "tui"]

log_file -a [file join $script_dir "smoke.txt"]

cd $tui_dir

spawn bun run tui
expect ">"

# Scenario 1 — Korean greeting
puts "\n===== SCENARIO 1: Korean greeting ====="
send "안녕하세요\r"
sleep 18

# Scenario 2 — Help
puts "\n===== SCENARIO 2: Help command ====="
send "/help\r"
sleep 6

# Scenario 3 — Public-service lookup
puts "\n===== SCENARIO 3: Public-service lookup ====="
send "강남역 어디야?\r"
sleep 45

# Scenario 4 — Weather routing
puts "\n===== SCENARIO 4: Weather routing ====="
send "오늘 서울 날씨 알려줘\r"
sleep 50

# Scenario 5 — Clean exit
puts "\n===== SCENARIO 5: Clean exit ====="
send "/quit\r"
sleep 3

expect eof
