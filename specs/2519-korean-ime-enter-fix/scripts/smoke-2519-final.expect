#!/usr/bin/env expect
# PTY smoke driver — PR #2519 final combined-fix verification.
#
# Captures two citizen turns:
#   (1) "너 어떤 모델이야?"  — verifies KOSMOS prompt is in effect, not the
#       CC dev-mode body. Expectation: K-EXAONE answers as a Korean public-
#       service assistant, NOT as a software engineering helper.
#   (2) "부산 사하구 동아대 위치 알려줘"  — verifies dispatchPrimitive
#       server-side-ack stub no longer renders. Expectation: lookup tool_use
#       blocks appear cleanly, "(어댑터 미상)" + "dispatched_via" JSON do
#       NOT appear under the ⎿ gutter.

set timeout 180

set log_path [file normalize "[file dirname [info script]]/../smoke-2519-final-pty.txt"]
log_file -noappend $log_path

spawn bash -c "cd [file normalize [file join $env(HOME) KOSMOS tui]] && bun run tui"

expect {
    "KOSMOS" { }
    timeout { puts stderr "\[SMOKE ERROR\] Timed out waiting for branding"; exit 1 }
    eof { puts stderr "\[SMOKE ERROR\] TUI exited before branding"; exit 1 }
}

sleep 3

# Turn 1 — meta-identity question.
send "너 어떤 모델이야?\r"
sleep 30

# Turn 2 — citizen lookup query that previously surfaced the stub regression.
send "부산 사하구 동아대 위치 알려줘\r"
sleep 60

# Clean exit.
send "\003"
sleep 1
send "\003"

expect {
    eof { }
    timeout { puts stderr "\[SMOKE WARN\] TUI did not exit cleanly after Ctrl+C" }
}

puts "SMOKE CAPTURE: $log_path"
