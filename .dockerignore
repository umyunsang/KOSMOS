# KOSMOS .dockerignore — FR-A05
# Keep the build context small so the runtime image stays <= 2 GB.
# Everything listed here is excluded from `docker build` context.

# Version control
.git
.gitignore
.gitattributes

# Virtual environments + caches
.venv
.pytest_cache
.mypy_cache
.ruff_cache
__pycache__
*.py[cod]
*$py.class

# Test + spec + docs (not needed at runtime)
tests/
specs/
docs/
.specify/

# Spec 1636 P5 carve-out — pyproject.toml [tool.hatch.build.targets.wheel.force-include]
# bundles two files into the wheel that hatchling resolves at build time
# (it fails with FileNotFoundError if absent from the build context):
#   - docs/plugins/security-review.md → kosmos/_canonical/security-review.md
#   - tests/fixtures/plugin_validation/checklist_manifest.yaml → kosmos/_canonical/...
# Negate the broad excludes above for these two leaves so they ship as
# wheel resources and Q9 OTEL emit / kosmos-plugin-validate work in
# production wheels. Total carve-out ≈ 40 KB; preserves the SC-1 ≤ 2 GB
# image budget.
!docs/plugins/
!docs/plugins/security-review.md
!tests/fixtures/
!tests/fixtures/plugin_validation/
!tests/fixtures/plugin_validation/checklist_manifest.yaml

# CI / tooling
.github/
.claude/
.vscode/
.idea/

# Node artifacts (kept out of Python image)
node_modules/

# Logs + ephemeral files
*.log
*.pid
*.swp
.DS_Store

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Environment files (never bake secrets into the image)
.env
.env.*
secrets/
