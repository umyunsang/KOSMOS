#!/usr/bin/env expect
# PTY smoke driver — PR #2519 commit f5a2c7a (shape mismatch fix)
#
# Captures the assistant turn for "부산 사하구 동아대 위치 알려줘" so the
# full PTY transcript (incl. all tool_use blocks, ⎿ result rows, error
# messages) can be ANSI-stripped and read end-to-end as plain text.
#
# Verification: ANSI-strip the captured txt and assert that no
# '(어댑터 미상)' substring is present. Either the empty-search red hint
# OR a numbered candidate list MUST appear under the ⎿ gutter.

set timeout 90

set log_path [file normalize "[file dirname [info script]]/../smoke-2519-lookup-shape-pty.txt"]
log_file -noappend $log_path

spawn bash -c "cd [file normalize [file join $env(HOME) KOSMOS tui]] && bun run tui"

expect {
    "KOSMOS" { }
    timeout {
        puts stderr "\[SMOKE ERROR\] Timed out waiting for KOSMOS branding"
        exit 1
    }
    eof {
        puts stderr "\[SMOKE ERROR\] TUI process exited before branding rendered"
        exit 1
    }
}

sleep 3

# Send the citizen query that previously surfaced the regression.
send "부산 사하구 동아대 위치 알려줘\r"

# Allow up to 60s for the K-EXAONE turn + tool dispatch + result rendering.
sleep 60

# Snapshot Ctrl+C exit so the spawn finishes cleanly even if streaming
# is still in flight.
send "\003"
sleep 1
send "\003"

expect {
    eof { }
    timeout { puts stderr "\[SMOKE WARN\] TUI did not exit cleanly after Ctrl+C" }
}

puts "SMOKE CAPTURE: PTY log written to $log_path"
