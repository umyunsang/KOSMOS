#!/usr/bin/env expect -f
# Spec 2293 Epic β — interactive /help slash command scenario.
# Validates that the post-cleanup TUI:
#  1. boots cleanly with KOSMOS branding (UFO mascot + K-EXAONE banner)
#  2. opens the slash-command autocomplete dropdown when "/" is typed
#  3. dispatches /help and renders the help payload
#  4. exits cleanly via Ctrl-C
# Companion artefact: smoke-help-pty.txt (text log for LLM grep)
#                     smoke-help.gif (vhs visual companion)
set timeout 45

set spec_dir [file dirname [file dirname [info script]]]
set log_path "$spec_dir/smoke-help-pty.txt"

set env(KOSMOS_BACKEND_CMD) "sleep 60"

spawn script -q $log_path bash -c "cd /Users/um-yunsang/KOSMOS-w-2293/tui && bun run tui"

expect {
  -re ".*KOSMOS.*" { puts "CHECKPOINTKOSMOS branding observed" }
  timeout { puts "FAILKOSMOS branding never appeared"; exit 1 }
}

sleep 3
puts "STEPsending /help"
send -- "/help\r"
sleep 6

puts "STEPsending Ctrl-C (first)"
send -- "\003"
sleep 1
puts "STEPsending Ctrl-C (second)"
send -- "\003"
sleep 1
puts "DONEcapture complete"
expect eof
