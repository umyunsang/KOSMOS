{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kosmos.example/schemas/029/nfa_emergency_info_service.output.schema.json",
  "title": "NfaEmergencyInfoServiceOutput",
  "description": "Output envelope for the nfa_emergency_info_service adapter. For the interface-only phase (this spec), registration uses a RootModel[dict[str, Any]] stub; this schema is the target shape that the stub will be swapped for when the Layer 3 auth-gate (Epic #16 / #20) lands. Item schema depends on the operation discriminator — operation-specific $defs reflect NFA docx TABLES 4/8/12/16/20/24.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "operation",
    "result_code",
    "result_msg",
    "page_no",
    "num_of_rows",
    "total_count",
    "items"
  ],
  "properties": {
    "operation": {
      "description": "Queried operation path (e.g. 'getEmgencyActivityInfo').",
      "type": "string"
    },
    "result_code": {
      "description": "API resultCode ('00' = NORMAL SERVICE).",
      "type": "string"
    },
    "result_msg": {
      "description": "API resultMsg.",
      "type": "string"
    },
    "page_no": {
      "type": "integer",
      "minimum": 1
    },
    "num_of_rows": {
      "type": "integer",
      "minimum": 0
    },
    "total_count": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "description": "List of emergency-info records. Empty list when no records match. Item schema depends on the 'operation' discriminator.",
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/NfaActivityItem" },
          { "$ref": "#/$defs/NfaTransferItem" },
          { "$ref": "#/$defs/NfaConditionItem" },
          { "$ref": "#/$defs/NfaFirstaidItem" },
          { "$ref": "#/$defs/NfaVehicleDispatchItem" },
          { "$ref": "#/$defs/NfaVehicleInfoItem" }
        ]
      }
    }
  },
  "$defs": {
    "NfaActivityItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgencyActivityInfo (TABLE 24).",
      "additionalProperties": true,
      "required": ["sidoHqOgidNm", "rsacGutFsttOgidNm", "gutYm"],
      "properties": {
        "sidoHqOgidNm": { "type": "string", "description": "시도본부" },
        "rsacGutFsttOgidNm": { "type": "string", "description": "출동소방서" },
        "gutYm": { "type": "string", "description": "출동년월 YYYYMM" },
        "gutHh": { "type": ["string", "null"] },
        "sptMvmnDtc": { "type": ["string", "null"], "description": "현장과의거리 (metres)" },
        "ptntAge": { "type": ["string", "null"], "description": "환자연령 bracket" },
        "ptntSdtSeCdNm": { "type": ["string", "null"] },
        "egrcSidoCdNm": { "type": ["string", "null"] },
        "egrcSiggCdNm": { "type": ["string", "null"] },
        "ruptOccrPlcCdNm": { "type": ["string", "null"] },
        "ruptSptmCdNm": { "type": ["string", "null"], "description": "환자증상" },
        "rcptPathCdNm": { "type": ["string", "null"] },
        "cptcSeCdNm": { "type": ["string", "null"] },
        "frnrAt": { "type": ["string", "null"] },
        "emtpQlcClCd1Nm": { "type": ["string", "null"] },
        "emtpQlcClCd2Nm": { "type": ["string", "null"] },
        "emtpQlcClCd3Nm": { "type": ["string", "null"] }
      }
    },
    "NfaTransferItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgPatientTransferInfo (TABLE 4).",
      "additionalProperties": true,
      "required": ["sidoHqOgidNm", "rsacGutFsttOgidNm", "stmtYm"],
      "properties": {
        "sidoHqOgidNm": { "type": "string" },
        "rsacGutFsttOgidNm": { "type": "string" },
        "stmtYm": { "type": "string" },
        "stmtHh": { "type": ["string", "null"] },
        "rlifAcdAsmCdNm": { "type": ["string", "null"], "description": "구급사고유형" },
        "ptntAge": { "type": ["string", "null"] },
        "ptntSdtSeCdNm": { "type": ["string", "null"] },
        "frnrAt": { "type": ["string", "null"] },
        "ptntTyCdNm": { "type": ["string", "null"], "description": "환자유형" },
        "ruptOccrPlcCdNm": { "type": ["string", "null"] },
        "rlifOccrTyCdNm": { "type": ["string", "null"] },
        "anmlInctCdNm": { "type": ["string", "null"] },
        "wmhtDamgCdNm": { "type": ["string", "null"] }
      }
    },
    "NfaConditionItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgPatientConditionInfo (TABLE 8).",
      "additionalProperties": true,
      "required": ["ruptSptmCdNm", "sidoHqOgidNm", "rsacGutFsttOgidNm", "stmtYm"],
      "properties": {
        "ruptSptmCdNm": { "type": "string" },
        "sidoHqOgidNm": { "type": "string" },
        "rsacGutFsttOgidNm": { "type": "string" },
        "stmtYm": { "type": "string" },
        "stmtHh": { "type": ["string", "null"] },
        "ptntAge": { "type": ["string", "null"] },
        "lwsBpsr": { "type": ["string", "null"], "description": "최저혈압" },
        "topBpsr": { "type": ["string", "null"], "description": "최고혈압" },
        "ptntHbco": { "type": ["string", "null"], "description": "심박수" },
        "ptntBfco": { "type": ["string", "null"], "description": "호흡수" },
        "ptntOsv": { "type": ["string", "null"], "description": "산소포화도" },
        "ptntBht": { "type": ["string", "null"], "description": "체온" }
      }
    },
    "NfaFirstaidItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgPatientFirstaidInfo (TABLE 12).",
      "additionalProperties": true,
      "required": ["sidoHqOgidNm", "rsacGutFsttOgidNm", "stmtYm"],
      "properties": {
        "sidoHqOgidNm": { "type": "string" },
        "rsacGutFsttOgidNm": { "type": "string" },
        "stmtYm": { "type": "string" },
        "stmtHh": { "type": ["string", "null"] },
        "ptntAge": { "type": ["string", "null"] },
        "ptntSdtSeCdNm": { "type": ["string", "null"] },
        "fstaCdNm": { "type": ["string", "null"], "description": "응급처치코드" }
      }
    },
    "NfaVehicleDispatchItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgVehicleDispatchInfo (TABLE 16).",
      "additionalProperties": true,
      "required": ["sidoHqOgidNm", "rsacGutFsttOgidNm", "stmtYm", "vctpCdNm"],
      "properties": {
        "sidoHqOgidNm": { "type": "string" },
        "rsacGutFsttOgidNm": { "type": "string" },
        "stmtYm": { "type": "string" },
        "stmtHh": { "type": ["string", "null"] },
        "vctpCdNm": { "type": "string", "description": "차종코드명" },
        "vhclSeCd": { "type": ["string", "null"] },
        "vhclNo": { "type": ["string", "null"] },
        "vhclStatCdNm": { "type": ["string", "null"] },
        "gotFrmtAt": { "type": ["string", "null"] },
        "vhcn": { "type": ["string", "null"] },
        "vhclGrCdNm": { "type": ["string", "null"] },
        "mnm": { "type": ["string", "null"] },
        "mdnm": { "type": ["string", "null"] },
        "gutPcnt": { "type": ["string", "null"] },
        "tnkCpct": { "type": ["string", "null"] },
        "gutOdr": { "type": ["string", "null"] }
      }
    },
    "NfaVehicleInfoItem": {
      "type": "object",
      "description": "Item shape for operation=getEmgVehicleInfo (TABLE 20).",
      "additionalProperties": true,
      "required": ["sidoHqOgidNm", "rsacGutFsttOgidNm"],
      "properties": {
        "sidoHqOgidNm": { "type": "string" },
        "rsacGutFsttOgidNm": { "type": "string", "description": "소방서" },
        "vhclSeCd": { "type": ["string", "null"] },
        "vhclNo": { "type": ["string", "null"] },
        "vctpCdNm": { "type": ["string", "null"] },
        "vhclStatCdNm": { "type": ["string", "null"] },
        "gotFrmtAt": { "type": ["string", "null"] },
        "vhcn": { "type": ["string", "null"] },
        "vhclGrCdNm": { "type": ["string", "null"] },
        "mnm": { "type": ["string", "null"] },
        "mdnm": { "type": ["string", "null"] },
        "bdgPcnt": { "type": ["string", "null"] },
        "tnkCpct": { "type": ["string", "null"] },
        "stde": { "type": ["string", "null"], "description": "기준일자 YYYYMMDD" }
      }
    }
  }
}
