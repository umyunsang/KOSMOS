#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Spec 2522 T047 — TUI PTY smoke scenario 6: 서울 강남구 교통사고 (US6)
#
# Pattern: scripts/tui-tmux-capture.sh (tmux capture-pane, NOT asciinema-in-asciinema)
# Memory: feedback_debug_infra_rebuild — wait_for_pane <regex> <deadline>, no hardcoded sleep
#
# Verification targets (autonomous 2-turn chain):
#   1. Boot: "tool_registry: N entries verified"
#   2. Branding: "UMMAYA" — idle state confirmed
#   3. Input accepted
#   4. Active LLM processing: "esc to interrupt" footer (NOT "? for shortcuts")
#      This uniquely identifies the TUI is actively processing — cannot appear in idle state.
#   5. KOROAD tool dispatch OR tool result:
#      "● lookup(koroad_accident" OR "⎿" with koroad content
#   6. Final response keywords: spot_nm, 위험, 사고, 강남 etc.
#
# CRITICAL GATE FIX (2026-05-03 regression analysis):
#   Stage C spinner gate MUST NOT use "·" — that character appears in the IDLE
#   branding text "K-EXAONE with high effort · API Usage Billing" and causes
#   immediate false match before LLM starts processing.
#   CORRECT gate: "esc to interrupt" — only appears in TUI footer during active LLM call.
#
# Gate timing note:
#   K-EXAONE with high effort: reasoning ~83s for this query.
#   Tool calls appear at end of response, persist until turn completes.
#   "⎿  검색 오류: Invalid parameters for tool." confirms KOROAD was called.
#
# Sourced by tui-tmux-capture.sh — helpers available:
#   wait_for_pane, snapshot_pane, send_text_pane, send_enter_pane, send_ctrlc_pane

# Stage A1: Wait for backend boot
wait_for_pane "tool_registry: [0-9]+ entries verified" 45
snapshot_pane "boot"

# Stage A2: Wait for UMMAYA branding / REPL ready (idle state confirmed)
# "? for shortcuts" only appears in idle state
wait_for_pane "UMMAYA" 20
snapshot_pane "branding"

# Stage B: Submit the query
send_text_pane "서울 강남구 교통사고 위험지역 알려줘"
snapshot_pane "input-typed"
send_enter_pane
snapshot_pane "input-submitted"

# Stage C: Wait for ACTIVE LLM processing
# "esc to interrupt" ONLY appears in footer during active LLM processing.
# It NEVER appears in the idle state (idle shows "? for shortcuts").
# This is the reliable gate that confirms the query was accepted and LLM started.
wait_for_pane "esc to interrupt" 30
snapshot_pane "llm-active"

# Stage D: Wait for KOROAD tool result in pane
# The LLM calls koroad_accident_search or koroad_accident_hazard_search.
# "⎿" (tool result delimiter) persists on screen after tool completes.
# "koroad_accident" appears in the tool call display line "● lookup(koroad_accident_*)".
# Deadline 150s: K-EXAONE reasoning takes ~83s for this query type.
wait_for_pane "(koroad_accident|⎿)" 150
snapshot_pane "koroad-call-or-result"

# Stage E: Capture additional state after KOROAD call
snapshot_pane "koroad-evidence"

# Stage F: Wait for turn to complete (idle state returns)
# "? for shortcuts" footer reappears when REPL returns to idle.
# K-EXAONE takes ~83s total — after koroad_accident text appears in streaming
# response, the LLM still needs time to finish the full response + tool calls.
# Deadline: 120s to cover remaining generation time after Stage D match.
wait_for_pane "[?] for shortcuts" 120
snapshot_pane "response-complete"

# Stage G: Final capture
snapshot_pane "final-before-quit"

# Quit cleanly
send_text_pane "/quit"
send_enter_pane
