# KOSMOS environment template
# Copy to `.env` (which is a gitignored symlink to your secrets store) and fill in values.
# See docs/configuration.md for the authoritative registry.
# All `<redacted>` placeholders must be replaced with real values before running.

# --- Required in dev/ci/prod (guard enforces non-empty) ---
KOSMOS_KAKAO_API_KEY=<redacted>  # consumed by kosmos.settings.KosmosSettings.kakao_api_key
KOSMOS_FRIENDLI_TOKEN=<redacted>  # consumed by kosmos.llm.config.LLMClientConfig.token
KOSMOS_DATA_GO_KR_API_KEY=<redacted>  # consumed by kosmos.settings.KosmosSettings.data_go_kr_api_key

# --- Optional fallback (resolve_location.py logs-and-skips when unset) ---
# KOSMOS_JUSO_CONFM_KEY=<redacted>  # consumed by kosmos.settings.KosmosSettings.juso_confm_key
# KOSMOS_SGIS_KEY=<redacted>  # consumed by kosmos.settings.KosmosSettings.sgis_key
# KOSMOS_SGIS_SECRET=<redacted>  # consumed by kosmos.settings.KosmosSettings.sgis_secret

# --- Required in prod only (conditional) ---
LANGFUSE_PUBLIC_KEY=<redacted>  # consumed by kosmos.observability.langfuse (#501)
LANGFUSE_SECRET_KEY=<redacted>  # consumed by kosmos.observability.langfuse (#501)
KOSMOS_OTEL_ENDPOINT=<redacted>  # consumed by kosmos.observability.otel (#501)

# --- Optional (defaults apply) ---
# KOSMOS_ENV=dev  # activation flag: dev | ci | prod (default dev)
# KOSMOS_FRIENDLI_BASE_URL=<redacted>  # consumed by kosmos.llm.config.LLMClientConfig.base_url
# KOSMOS_FRIENDLI_MODEL=<redacted>  # consumed by kosmos.llm.config.LLMClientConfig.model
# KOSMOS_LLM_SESSION_BUDGET=<redacted>  # consumed by kosmos.llm.config.LLMClientConfig.session_budget
# KOSMOS_LOOKUP_TOPK=5  # consumed by kosmos.settings.KosmosSettings.lookup_topk; clamped [1, 20]
# KOSMOS_NMC_FRESHNESS_MINUTES=30  # consumed by kosmos.settings.KosmosSettings.nmc_freshness_minutes; clamped [1, 1440]
# KOSMOS_CLI_HISTORY_SIZE=<redacted>  # consumed by kosmos.cli.config.CLIConfig.history_size
# KOSMOS_CLI_SHOW_USAGE=<redacted>  # consumed by kosmos.cli.config.CLIConfig.show_usage
# KOSMOS_CLI_WELCOME_BANNER=<redacted>  # consumed by kosmos.cli.config.CLIConfig.welcome_banner
# KOSMOS_CLI_THEME=<redacted>  # consumed by kosmos.cli.themes.load_theme (alias for KOSMOS_THEME)
# KOSMOS_THEME=<redacted>  # consumed by kosmos.cli.themes.load_theme

# --- Override pattern (escape hatch) ---
# KOSMOS_<TOOL_ID>_API_KEY=<redacted>  # per-tool override, e.g. KOSMOS_KOROAD_ACCIDENT_SEARCH_API_KEY; see docs/configuration.md

# --- Deprecated (scheduled for removal) ---
# KOSMOS_API_KEY=<redacted>  # legacy global fallback — do not set in new installs; consumed by kosmos.permissions.credentials (global fallback)
