{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "target": "es2022",
    "module": "esnext",
    "types": ["bun-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "lib": ["es2022"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "src/*": ["./src/*"],
      "bun:bundle": ["./src/stubs/bun-bundle.ts"],
      "react/compiler-runtime": ["./src/stubs/react-compiler-runtime"],
      "@datadog/browser-logs": ["./src/stubs/any-stub"],
      "@ant/claude-for-chrome-mcp": ["./src/stubs/any-stub"],
      "@ant/computer-use-mcp": ["./src/stubs/any-stub"],
      "@ant/computer-use-swift": ["./src/stubs/any-stub"],
      "@ant/computer-use-input": ["./src/stubs/any-stub"],
      "color-diff-napi": ["./src/stubs/color-diff-napi.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "src/ink/**",
    "src/utils/**",
    "tests/ink/**",
    "scripts/soak.ts"
  ]
}
